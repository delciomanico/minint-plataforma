import { createClient } from "@/lib/supabase/server"
import type { Profile } from "@/lib/types"

export async function getCurrentUser(): Promise<{ user: any; profile: Profile | null }> {
  const supabase = await createClient()

  const {
    data: { user },
    error: userError,
  } = await supabase.auth.getUser()

  if (userError || !user) {
    return { user: null, profile: null }
  }

  const { data: profile, error: profileError } = await supabase.from("profiles").select("*").eq("id", user.id).single()

  if (profileError) {
    console.error("Error fetching profile:", profileError)
    return { user, profile: null }
  }

  return { user, profile }
}

export function hasPermission(userRole: string, requiredRoles: string[]): boolean {
  return requiredRoles.includes(userRole)
}

export function isAdmin(userRole: string): boolean {
  return userRole === "admin"
}

export function isSupervisor(userRole: string): boolean {
  return ["admin", "supervisor"].includes(userRole)
}

export function canManageUsers(userRole: string): boolean {
  return ["admin", "supervisor"].includes(userRole)
}

export function canViewAllComplaints(userRole: string): boolean {
  return ["admin", "supervisor", "analyst"].includes(userRole)
}
